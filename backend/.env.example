# Parsed by django-environ. Copy to .env for local runs: cp .env.example .env

# --- Django ---------------------------------------------------------------
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# --- Database (django-environ URL form) -----------------------------------
# Leave unset to use SQLite (zero-config). For Postgres:
# DATABASE_URL=postgres://hos:hos@db:5432/hos

# --- CORS -----------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- OpenRouteService -----------------------------------------------------
# Optional. Without a key the backend uses an offline distance/geocode
# estimator (known US cities only). Set this for real truck routing + geometry.
# ORS_API_KEY=your-ors-key

# --- Misc -----------------------------------------------------------------
# TRIP_CACHE_TTL=3600
# LOG_LEVEL=INFO
