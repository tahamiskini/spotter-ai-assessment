# Base URL of the Django API (include the /api prefix).
VITE_APP_API_URL=http://localhost:8000/api

# Set to "true" to serve responses from the in-browser MSW mocks instead
# of hitting the real backend. Useful for frontend-only development.
VITE_APP_ENABLE_API_MOCKING=false

# Public URL of this frontend (used by the mock server CORS config).
VITE_APP_URL=http://localhost:3000

# Port the standalone mock API server listens on.
VITE_APP_MOCK_API_PORT=8080
